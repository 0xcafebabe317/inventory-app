.today-page { padding: 12px; }

.sale-card {
  background: #fff; border-radius: 10px; padding: 14px 16px; margin-bottom: 8px;
  box-shadow: 0 1px 2px rgba(0,0,0,0.04);
}
.sale-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px; }
.sale-customer { font-size: 15px; font-weight: 600; }
.sale-amount { font-size: 22px; font-weight: 700; color: #ee0a24; margin-bottom: 6px; }
.sale-meta { font-size: 12px; color: #969799; }
