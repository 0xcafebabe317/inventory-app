<view class="container">
  <!-- Trial banner -->
  <view wx:if="{{trialDaysLeft > 0 && trialDaysLeft <= 3}}" class="trial-banner">
    试用期还剩 {{trialDaysLeft}} 天
  </view>

  <!-- Stats cards -->
  <view class="stats-grid">
    <view class="stats-item">
      <text class="stats-label">今日销售</text>
      <text class="stats-value">¥{{todaySales}}</text>
    </view>
    <view class="stats-item">
      <text class="stats-label">今日利润</text>
      <text class="stats-value text-success">¥{{todayProfit}}</text>
    </view>
    <view class="stats-item">
      <text class="stats-label">本月销售</text>
      <text class="stats-value">¥{{monthSales}}</text>
    </view>
    <view class="stats-item">
      <text class="stats-label">本月利润</text>
      <text class="stats-value text-success">¥{{monthProfit}}</text>
    </view>
  </view>

  <!-- AR card -->
  <view class="card" wx:if="{{customersWithDebt.length > 0}}">
    <view class="card-title row space-between">
      <text>应收账款</text>
      <text class="text-xl text-danger">¥{{totalAr}}</text>
    </view>
    <view wx:for="{{customersWithDebt}}" wx:key="id" class="debt-item" data-id="{{item.id}}" bindtap="goToCustomer">
      <text>{{item.name}}</text>
      <text class="text-danger">¥{{item.balance_fmt}}</text>
    </view>
  </view>

  <!-- Low stock -->
  <view class="card" wx:if="{{lowStockCount > 0}}" bindtap="goToInventory">
    <view class="row space-between">
      <text class="text-warning">⚠ {{lowStockCount}} 个商品库存不足</text>
      <text class="text-secondary">查看 ›</text>
    </view>
  </view>

  <!-- Recent sales -->
  <view class="card">
    <view class="card-title">最近销售</view>
    <view wx:if="{{recentSales.length === 0}}" class="empty-state" style="padding:24px">
      <text class="text-secondary">暂无记录</text>
    </view>
    <view wx:for="{{recentSales}}" wx:key="id" class="sale-row" data-id="{{item.id}}" bindtap="goToSaleDetail">
      <view class="row space-between">
        <view>
          <text>{{item.customer_name}}</text>
          <text class="tag tag-primary ml-8">{{item.pay_method === 'credit' ? '赊账' : '已收'}}</text>
        </view>
        <text class="text-large">¥{{item.total_amount_fmt}}</text>
      </view>
      <text class="text-secondary">{{item.created_at_fmt}}</text>
    </view>
  </view>
</view>
