<view class="dashboard">
  <!-- Trial banner -->
  <view wx:if="{{trialDaysLeft > 0 && trialDaysLeft <= 3}}" class="trial-banner">
    ⏰ 试用期还剩 {{trialDaysLeft}} 天
  </view>

  <!-- KPI Stats -->
  <view class="stats-grid">
    <view class="stat-card" style="border-top:3px solid #2563eb">
      <view class="stat-top"><text class="stat-icon">💰</text><text class="stat-label">今日销售</text></view>
      <text class="stat-value" style="color:#2563eb">¥{{todaySales}}</text>
    </view>
    <view class="stat-card" style="border-top:3px solid #16a34a">
      <view class="stat-top"><text class="stat-icon">📈</text><text class="stat-label">今日利润</text></view>
      <text class="stat-value" style="color:#16a34a">¥{{todayProfit}}</text>
    </view>
    <view class="stat-card" style="border-top:3px solid #f59e0b">
      <view class="stat-top"><text class="stat-icon">📊</text><text class="stat-label">本月销售</text></view>
      <text class="stat-value" style="color:#f59e0b">¥{{monthSales}}</text>
    </view>
    <view class="stat-card" style="border-top:3px solid #8b5cf6">
      <view class="stat-top"><text class="stat-icon">✨</text><text class="stat-label">本月利润</text></view>
      <text class="stat-value" style="color:#8b5cf6">¥{{monthProfit}}</text>
    </view>
  </view>

  <!-- Accounts Receivable -->
  <view wx:if="{{customersWithDebt.length > 0}}" class="card ar-card" data-id="{{customersWithDebt[0].id}}" bindtap="goToCustomer">
    <view class="card-title">
      <text>💳 应收账款</text>
      <van-tag type="danger" size="medium">{{customersWithDebt.length}}人</van-tag>
    </view>
    <view class="ar-total">¥{{totalAr}}</view>
    <view wx:for="{{customersWithDebt}}" wx:for-item="c" wx:key="id" class="ar-item">
      <text>{{c.name}}</text>
      <text class="text-danger">¥{{c.balance_fmt}}</text>
    </view>
  </view>

  <!-- Recent Sales / Purchases Tabs -->
  <view class="card">
    <!-- Tab Header -->
    <view class="recents-header">
      <view class="recents-tabs">
        <view class="recents-tab {{activeTab === 'sale' ? 'recents-tab-active' : ''}}" data-tab="sale" bindtap="switchTab">
          <text>最近销售</text>
        </view>
        <view class="recents-tab {{activeTab === 'purchase' ? 'recents-tab-active' : ''}}" data-tab="purchase" bindtap="switchTab">
          <text>最近进货</text>
        </view>
      </view>
      <view wx:if="{{activeTab === 'sale'}}" class="recents-more" bindtap="goToRecentSales">
        <text class="recents-more-text">最近一周</text>
        <van-icon name="arrow" size="12px" color="#969799" />
      </view>
      <view wx:else class="recents-more" bindtap="goToRecentPurchases">
        <text class="recents-more-text">最近一周</text>
        <van-icon name="arrow" size="12px" color="#969799" />
      </view>
    </view>

    <!-- Sale List -->
    <view wx:if="{{activeTab === 'sale'}}">
      <view wx:if="{{recentSales.length === 0}}" class="empty-state">
        <text class="text-secondary">暂无销售记录</text>
      </view>
      <view wx:for="{{recentSales}}" wx:key="id" class="sale-item" data-id="{{item.id}}" bindtap="goToSaleDetail">
        <view class="sale-row">
          <text class="sale-customer">{{item.customer_name}}</text>
          <text class="sale-amount">¥{{item.total_amount_fmt}}</text>
        </view>
        <view class="sale-meta">
          <van-tag type="{{item.pay_method === 'credit' ? 'warning' : 'success'}}" size="medium">{{item.pay_method === 'credit' ? '赊账' : '已收'}}</van-tag>
          <text class="text-secondary">{{item.created_at_fmt}}</text>
        </view>
      </view>
    </view>

    <!-- Purchase List -->
    <view wx:else>
      <view wx:if="{{recentPurchases.length === 0}}" class="empty-state">
        <text class="text-secondary">暂无进货记录</text>
      </view>
      <view wx:for="{{recentPurchases}}" wx:key="id" class="sale-item" data-id="{{item.id}}" bindtap="goToPurchaseDetail">
        <view class="sale-row">
          <text class="sale-customer">{{item.supplier_name}}</text>
          <text class="sale-amount" style="color:#1a56db">¥{{item.total_amount_fmt}}</text>
        </view>
        <view class="sale-meta">
          <text class="text-secondary">{{item.created_at_fmt}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
