<view class="detail-page">
  <view class="balance-card">
    <view class="cust-name">{{customer.name}}</view>
    <view class="text-secondary">{{customer.phone || ''}}</view>
    <view class="balance-amount {{parseFloat(balance) > 0 ? 'text-danger' : 'text-success'}}">¥{{balance}}</view>
    <view class="balance-label">待还金额</view>
  </view>

  <van-button type="primary" block round bindtap="showRepay" custom-style="margin-bottom:12px">记录还款</van-button>

  <view class="card">
    <view class="card-title">往来明细</view>
    <view wx:if="{{transactions.length === 0}}" style="text-align:center;padding:24px;color:#969799">暂无记录</view>
    <view wx:for="{{transactions}}" wx:key="index" class="txn-row">
      <view class="txn-top">
        <van-tag type="{{item.type === 'sale' ? 'warning' : 'success'}}" size="medium">{{item.type_label}}</van-tag>
        <text class="txn-amount {{item.type_class}}">{{item.type === 'sale' ? '-' : '+'}}¥{{item.amount_fmt}}</text>
      </view>
      <text class="text-secondary">{{item.date}}</text>
    </view>
  </view>

  <!-- Repay Popup -->
  <van-popup show="{{showRepayDialog}}" bind:close="onCloseRepay" position="bottom" round custom-style="padding:20px">
    <view class="popup-title">记录还款</view>
    <van-field value="{{repayAmount}}" type="digit" label="金额" placeholder="0.00" bind:change="onRepayInput" />
    <view class="pay-row">
      <van-button size="small" type="{{repayMethod === 'wechat' ? 'primary' : 'default'}}" data-method="wechat" bindtap="onSelectRepayMethod">微信</van-button>
      <van-button size="small" type="{{repayMethod === 'alipay' ? 'primary' : 'default'}}" data-method="alipay" bindtap="onSelectRepayMethod">支付宝</van-button>
      <van-button size="small" type="{{repayMethod === 'cash' ? 'primary' : 'default'}}" data-method="cash" bindtap="onSelectRepayMethod">现金</van-button>
    </view>
    <van-button type="primary" block round loading="{{submitting}}" bindtap="submitRepay" custom-style="margin-top:16px">确认还款</van-button>
  </van-popup>
</view>
