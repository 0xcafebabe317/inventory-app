.scan-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  height: 56px;
  font-size: 16px;
  font-weight: 500;
  color: #1989fa;
  border: 1px dashed #1989fa;
  border-radius: 8px;
}

.scan-icon { font-size: 22px; }

.modal-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5); z-index: 100;
  display: flex; align-items: flex-end;
}

.modal-content {
  background: #fff; width: 100%; max-height: 60vh;
  border-radius: 16px 16px 0 0; padding: 16px; overflow-y: auto;
}

.modal-title {
  font-size: 16px; font-weight: 600; margin-bottom: 12px; text-align: center;
}

.picker-item {
  display: flex; justify-content: space-between; align-items: center;
  padding: 12px 0; border-bottom: 1px solid #f5f5f5;
}

.item-row {
  display: flex; align-items: center; padding: 8px 0;
  border-bottom: 1px solid #f5f5f5;
}

.qty-btn {
  width: 28px; height: 28px; display: flex; align-items: center;
  justify-content: center; background: #f5f5f5; border-radius: 4px;
  font-size: 16px;
}

.qty-num { min-width: 32px; text-align: center; font-weight: 600; }

.remove-btn { color: #ee0a24; margin-left: 8px; padding: 4px; }

.pay-methods { display: flex; gap: 8px; }
.pay-item {
  flex: 1; text-align: center; padding: 8px; border-radius: 4px;
  border: 1px solid #ebedf0; font-size: 13px;
}
.pay-item.active { border-color: #1989fa; color: #1989fa; background: #e8f3ff; }

.amount-input {
  border: 1px solid #ebedf0; border-radius: 4px; padding: 4px 8px;
  width: 100px; display: inline-block;
}

.bottom-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: #fff; padding: 12px 16px; display: flex; align-items: center;
  border-top: 1px solid #ebedf0; box-shadow: 0 -2px 8px rgba(0,0,0,0.06);
}

.quick-actions { padding-bottom: 80px; }
