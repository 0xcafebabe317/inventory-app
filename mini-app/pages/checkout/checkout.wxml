<view class="checkout-page">
  <!-- Customer selector bar -->
  <view class="customer-bar">
    <text class="customer-bar-title">客户</text>
    <view class="customer-actions">
      <van-button type="{{!customerId ? 'primary' : 'default'}}" size="small" bindtap="clearCustomer">🧑 散客</van-button>
      <van-button type="{{customerId ? 'primary' : 'default'}}" size="small" bindtap="openCustomerPicker">🏪 {{customerName || '批发'}}</van-button>
    </view>
  </view>

  <!-- Product Search -->
  <van-cell-group inset custom-style="margin-bottom:8px">
    <van-field value="{{productSearch}}" placeholder="搜索商品名称" readonly right-icon="search" bind:click-input="openProductPicker" />
  </van-cell-group>

  <!-- Scan button -->
  <view class="scan-area" bindtap="onScan">
    📷 扫码添加商品
  </view>

  <!-- Cart Items -->
  <view wx:if="{{items.length > 0}}" class="cart-list">
    <view wx:for="{{items}}" wx:key="product_id" class="cart-item">
      <view class="cart-info">
        <view class="cart-name">{{item.name}}</view>
        <view class="cart-meta">{{item.spec || ''}} · ¥{{item.unit_price_fmt}}/{{item.unit || '个'}}</view>
      </view>
      <view class="cart-qty">
        <van-button size="mini" icon="minus" data-idx="{{index}}" data-delta="-1" bindtap="changeQty" />
        <input class="qty-input" type="number" value="{{item.qty}}" data-idx="{{index}}" bindinput="onQtyInput" bindblur="onQtyBlur" />
        <van-button size="mini" icon="plus" data-idx="{{index}}" data-delta="1" bindtap="changeQty" />
      </view>
      <view class="cart-sub">¥{{item.subtotal_fmt}}</view>
      <van-icon name="cross" size="16px" color="#c8c9cc" data-idx="{{index}}" bindtap="removeItem" style="margin-left:6px" />
    </view>
  </view>
  <view wx:else class="empty-hint">点击上方搜索框添加商品</view>

  <!-- Payment Method -->
  <view class="card" wx:if="{{items.length > 0}}">
    <view class="card-title">收款方式</view>
    <view class="pay-row">
      <van-button type="{{payMethod === 'wechat' ? 'primary' : 'default'}}" size="small" round data-method="wechat" bindtap="selectPayMethod">💚 微信</van-button>
      <van-button type="{{payMethod === 'alipay' ? 'primary' : 'default'}}" size="small" round data-method="alipay" bindtap="selectPayMethod">💙 支付宝</van-button>
      <van-button type="{{payMethod === 'cash' ? 'primary' : 'default'}}" size="small" round data-method="cash" bindtap="selectPayMethod">💵 现金</van-button>
    </view>
  </view>

  <!-- Bottom bar -->
  <view class="bottom-bar" wx:if="{{items.length > 0}}">
    <view class="total-row">
      <text>共 {{totalQty}} 件 · 合计</text>
      <text class="total-amount">¥{{totalAmount}}</text>
    </view>
    <van-button type="primary" size="large" round loading="{{submitting}}" disabled="{{items.length === 0}}" bindtap="submit" block>
      确认收款
    </van-button>
  </view>

  <!-- Product Picker Popup -->
  <van-popup show="{{showProductPicker}}" bind:close="closeProductPicker" position="bottom" custom-style="height:65%" round>
    <view class="picker-head">
      <van-search value="{{productSearch}}" placeholder="搜索商品" bind:search="searchProducts" bind:change="onPickerSearch" />
    </view>
    <view class="picker-body">
      <view wx:for="{{pickerProducts}}" wx:key="id" class="picker-item" data-product="{{item}}" bindtap="selectProduct">
        <view class="picker-info">
          <view class="picker-name">{{item.name}}</view>
          <view class="text-secondary">{{item.spec || ''}} · 库存{{item.stock_qty || 0}}{{item.unit || '个'}} · {{item.supplier_name || '未知供货商'}}</view>
        </view>
        <text class="picker-price">¥{{item.sale_price_fmt || item.sale_price}}</text>
      </view>
      <van-empty wx:if="{{allProducts.length === 0 && !productSearch}}" description="暂无商品">
        <van-button type="primary" size="small" bindtap="goToAddProduct">添加第一个商品</van-button>
      </van-empty>
      <van-empty wx:if="{{pickerProducts.length === 0 && productSearch}}" description="无匹配商品" />
    </view>
  </van-popup>

  <!-- Customer Picker Popup -->
  <van-popup show="{{showCustomerPicker}}" bind:close="closeCustomerPicker" position="bottom" custom-style="height:50%" round>
    <view class="picker-head"><view class="picker-title">选择客户</view></view>
    <view class="picker-body">
      <view wx:for="{{customers}}" wx:key="id" class="picker-item" data-customer="{{item}}" bindtap="selectCustomer">
        <view>
          <text>{{item.name}}</text>
          <text class="text-secondary" style="margin-left:8px">{{item.phone || ''}}</text>
        </view>
        <text wx:if="{{item.balance > 0}}" class="text-danger">欠 ¥{{item.balance.toFixed(2)}}</text>
      </view>
      <van-empty wx:if="{{customers.length === 0}}" description="暂无客户" />
    </view>
  </van-popup>
</view>
