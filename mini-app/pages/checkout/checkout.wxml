<view class="container">
  <!-- Scan button -->
  <view class="scan-btn card" bindtap="onScan">
    <text class="scan-icon">📷</text>
    <text>扫码添加商品</text>
  </view>

  <!-- Search -->
  <view class="search-bar">
    <input placeholder="搜索商品名称..." bindinput="onSearchInput" value="{{productSearch}}" />
  </view>

  <!-- Product picker modal -->
  <view wx:if="{{showProductPicker}}" class="modal-mask" bindtap="onClosePicker">
    <view class="modal-content" catchtap="">
      <view class="modal-title">选择商品</view>
      <view wx:if="{{products.length === 0}}" class="empty-state" style="padding:24px">
        <text class="text-secondary">未找到商品</text>
      </view>
      <view wx:for="{{products}}" wx:key="id" class="picker-item" data-product="{{item}}" bindtap="selectProduct">
        <view>
          <text>{{item.name}}</text>
          <text class="text-secondary ml-8">{{item.spec}}</text>
        </view>
        <view class="text-right">
          <text>¥{{item.sale_price}}</text>
          <text class="text-secondary ml-8">库存: {{item.stock_qty}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Selected items -->
  <view class="card" wx:if="{{items.length > 0}}">
    <view class="card-title">已选商品</view>
    <view wx:for="{{items}}" wx:key="product_id" class="item-row">
      <view class="flex-1">
        <text>{{item.name}}</text>
        <text class="text-secondary ml-8">{{item.unit_price_fmt}}/{{item.unit}}</text>
      </view>
      <view class="row">
        <view class="qty-btn" data-idx="{{index}}" data-delta="-1" bindtap="changeQty">−</view>
        <text class="qty-num">{{item.qty}}</text>
        <view class="qty-btn" data-idx="{{index}}" data-delta="1" bindtap="changeQty">+</view>
        <text class="ml-8" style="min-width:60px;text-align:right">{{item.subtotal_fmt}}</text>
        <text class="remove-btn" data-idx="{{index}}" bindtap="removeItem">✕</text>
      </view>
    </view>
  </view>

  <!-- Empty state -->
  <view wx:if="{{items.length === 0}}" class="empty-state">
    <text class="text-secondary">扫码或搜索添加商品</text>
  </view>

  <!-- Payment section -->
  <view class="card" wx:if="{{items.length > 0}}">
    <view class="card-title">收款方式</view>
    <view class="pay-methods">
      <view class="pay-item {{payMethod === 'cash' ? 'active' : ''}}" data-method="cash" bindtap="selectPayMethod">现金</view>
      <view class="pay-item {{payMethod === 'wechat' ? 'active' : ''}}" data-method="wechat" bindtap="selectPayMethod">微信</view>
      <view class="pay-item {{payMethod === 'alipay' ? 'active' : ''}}" data-method="alipay" bindtap="selectPayMethod">支付宝</view>
      <view class="pay-item {{payMethod === 'credit' ? 'active' : ''}}" data-method="credit" bindtap="selectPayMethod">赊账</view>
    </view>

    <!-- Customer picker for credit -->
    <view wx:if="{{payMethod === 'credit'}}" class="mt-12">
      <text class="text-secondary">赊账客户：</text>
      <text class="tag tag-warning" bindtap="onShowCustomerPicker">{{customerName || '点击选择客户'}}</text>
    </view>

    <!-- Customer picker modal -->
    <view wx:if="{{showCustomerPicker}}" class="modal-mask" bindtap="onCloseCustomerPicker">
      <view class="modal-content" catchtap="">
        <view class="modal-title">选择客户</view>
        <view wx:for="{{customers}}" wx:key="id" class="picker-item" data-customer="{{item}}" bindtap="selectCustomer">
          <text>{{item.name}}</text>
          <text class="text-secondary">{{item.phone || ''}}</text>
        </view>
      </view>
    </view>

    <!-- Partial payment for credit -->
    <view wx:if="{{payMethod === 'credit'}}" class="mt-8">
      <text class="text-secondary">已付金额：</text>
      <input class="amount-input" type="digit" placeholder="0.00" value="{{paidAmount}}" bindinput="onPaidAmountInput" />
    </view>
  </view>

  <!-- Bottom bar -->
  <view class="bottom-bar" wx:if="{{items.length > 0}}">
    <view class="flex-1">
      <text class="text-secondary">合计</text>
      <text class="text-xl ml-8">¥{{totalAmount}}</text>
    </view>
    <view class="btn btn-primary" bindtap="submit" style="width:120px">
      {{submitting ? '提交中...' : '确认收款'}}
    </view>
  </view>

  <!-- Quick actions -->
  <view class="quick-actions mt-16">
    <view class="btn btn-outline btn-block" bindtap="goToPurchase">📦 进货入库</view>
  </view>
</view>
