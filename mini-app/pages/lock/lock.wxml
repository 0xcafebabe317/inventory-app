<view class="lock-page">
  <view class="lock-content">
    <view class="lock-icon">🔒</view>
    <view class="lock-title">使用权限已到期</view>
    <view class="lock-desc">试用期已结束，请添加管理员微信继续使用</view>

    <van-button
      wx:if="{{!showQr}}"
      type="primary"
      block
      round
      bindtap="showAdminQr"
      custom-style="height:44px;font-size:15px"
    >联系管理员</van-button>

    <view wx:if="{{showQr}}" class="qr-card">
      <image
        src="/assets/admin-qr.png"
        mode="widthFix"
        class="qr-image"
        show-menu-by-longpress="{{true}}"
      />
      <view class="qr-tip">长按二维码保存图片，微信扫码添加管理员</view>
    </view>
  </view>
</view>
