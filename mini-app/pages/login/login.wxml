<view class="login-page">
  <view class="logo-area">
    <view class="logo-icon">🐰</view>
    <view class="app-title">兔子进销存</view>
    <view class="app-subtitle">手机号登录</view>
  </view>

  <view class="form-area">
    <van-cell-group inset>
      <van-field
        value="{{phone}}"
        placeholder="请输入手机号"
        type="number"
        maxlength="11"
        left-icon="phone-o"
        bind:change="onPhoneInput"
      />
      <van-field
        value="{{password}}"
        placeholder="请输入密码"
        type="password"
        left-icon="lock"
        bind:change="onPasswordInput"
      />
    </van-cell-group>

    <view style="margin: 24px 0">
      <van-button
        type="primary"
        block
        round
        loading="{{submitting}}"
        disabled="{{submitting}}"
        bindtap="handleLogin"
        loading-text="登录中..."
      >登录</van-button>
    </view>
  </view>

  <view class="footer-link" bindtap="goRegister">
    还没有账号？立即注册
  </view>
</view>
