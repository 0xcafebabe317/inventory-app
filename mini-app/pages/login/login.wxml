<view class="login-page">
  <view class="logo-area">
    <view class="logo-icon">🐰</view>
    <view class="app-title">兔子进销存</view>
    <view class="app-subtitle">手机号登录</view>
  </view>

  <view class="form-area">
    <van-cell-group inset>
      <van-field
        value="{{phone}}"
        placeholder="请输入手机号"
        type="number"
        maxlength="11"
        left-icon="phone-o"
        bind:change="onPhoneInput"
      />
      <van-field
        value="{{password}}"
        placeholder="请输入密码"
        type="password"
        left-icon="lock"
        bind:change="onPasswordInput"
      />
    </van-cell-group>

    <!-- 隐私声明 -->
    <view class="privacy-notice">
      <text class="privacy-icon">🔒</text>
      <text class="privacy-text">您的手机号仅用于注册登录，作为账号唯一标识，不会用于其他任何用途。</text>
    </view>

    <!-- 协议同意 -->
    <view class="agreement-row">
      <van-checkbox value="{{agreed}}" bind:change="onAgreeChange" />
      <text class="agreement-text">我已阅读并同意</text>
      <text class="agreement-link" bindtap="viewAgreement" data-type="service">《用户服务协议》</text>
      <text class="agreement-text">及</text>
      <text class="agreement-link" bindtap="viewAgreement" data-type="privacy">《隐私政策》</text>
    </view>

    <view style="margin: 16px 0">
      <van-button
        type="primary"
        block
        round
        loading="{{submitting}}"
        disabled="{{submitting || !agreed}}"
        bindtap="handleLogin"
        loading-text="登录中..."
      >登录</van-button>
    </view>
  </view>

  <view class="footer-link" bindtap="goRegister">
    还没有账号？立即注册
  </view>
</view>
