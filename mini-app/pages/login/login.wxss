.login-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #eff6ff 0%, #f0f4f8 100%);
  display: flex;
  flex-direction: column;
  padding-top: 80px;
}
.logo-area {
  text-align: center;
  margin-bottom: 32px;
}
.logo-icon {
  font-size: 60px;
  margin-bottom: 12px;
}
.app-title {
  font-size: 28px;
  font-weight: 700;
  color: #2563eb;
  margin-bottom: 8px;
}
.app-subtitle {
  font-size: 14px;
  color: #94a3b8;
}
.form-area {
  padding: 0 16px;
}
.privacy-notice {
  display: flex;
  align-items: flex-start;
  background: #f0f7ff;
  border-radius: 8px;
  padding: 12px;
  margin-top: 8px;
}
.privacy-icon {
  font-size: 16px;
  margin-right: 8px;
  flex-shrink: 0;
}
.privacy-text {
  font-size: 12px;
  color: #94a3b8;
  line-height: 1.6;
}
.agreement-row {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 16px;
  font-size: 12px;
  flex-wrap: wrap;
}
.agreement-text {
  color: #999;
}
.agreement-link {
  color: #2563eb;
}
.footer-link {
  text-align: center;
  margin-top: 24px;
  font-size: 14px;
  color: #2563eb;
}
