<view class="manage-page">
  <view class="toolbar">
    <text class="text-secondary">共 {{customers.length}} 位客户</text>
    <van-button size="small" type="primary" icon="plus" bindtap="showAdd">新增客户</van-button>
  </view>

  <view wx:if="{{customers.length === 0}}" style="text-align:center;padding:60px 0;color:#969799">
    <van-empty description="暂无客户">
      <van-button type="primary" size="small" bindtap="showAdd">添加第一个客户</van-button>
    </van-empty>
  </view>

  <view wx:for="{{customers}}" wx:key="id" class="manage-card">
    <view class="card-header">
      <view class="card-avatar">👤</view>
      <view class="card-info">
        <text class="manage-name">{{item.name}}</text>
        <view class="manage-meta">
          <text wx:if="{{item.phone}}">电话: {{item.phone}}</text>
          <text wx:if="{{item.wechat}}" class="text-secondary" style="margin-left:12px">微信: {{item.wechat}}</text>
        </view>
        <text wx:if="{{item.remark}}" class="text-secondary" style="margin-top:2px">{{item.remark}}</text>
      </view>
      <text wx:if="{{item.balance > 0}}" class="balance-badge">待还: ¥{{item.balance_fmt}}</text>
    </view>
    <view class="card-actions">
      <van-button size="small" plain type="primary" icon="edit" data-customer="{{item}}" bindtap="showEdit">修改信息</van-button>
      <van-button size="small" plain icon="records" data-id="{{item.id}}" bindtap="goTransactions">交易记录</van-button>
    </view>
  </view>

  <!-- Add/Edit Popup -->
  <van-popup show="{{showDialog}}" bind:close="closeDialog" position="bottom" custom-style="padding:20px 16px;border-radius:16px 16px 0 0" round>
    <view class="popup-title">{{dialogTitle}}</view>
    <view class="popup-form">
      <van-field value="{{form.name}}" label="名称" required placeholder="客户名称" bind:change="onNameInput" />
      <van-field value="{{form.phone}}" label="手机" type="number" placeholder="手机号" bind:change="onPhoneInput" />
      <van-field value="{{form.wechat}}" label="微信" placeholder="微信号" bind:change="onWechatInput" />
      <van-field value="{{form.remark}}" label="备注" placeholder="备注" bind:change="onRemarkInput" />
    </view>
    <view class="popup-actions">
      <van-button block round type="primary" loading="{{submitting}}" bindtap="handleSubmit">保存</van-button>
      <van-button block round plain type="default" bindtap="closeDialog" custom-style="margin-top:10px">取消</van-button>
    </view>
  </van-popup>
</view>
