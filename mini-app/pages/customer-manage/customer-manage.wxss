.manage-page { padding: 12px; padding-bottom: 40px; }
.toolbar { display: flex; justify-content: space-between; align-items: center; padding: 8px 4px; margin-bottom: 8px; }

.manage-card {
  background: #fff; border-radius: 10px; padding: 14px 16px; margin-bottom: 8px;
  box-shadow: 0 1px 2px rgba(0,0,0,0.04);
}
.manage-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px; }
.manage-name { font-size: 15px; font-weight: 600; }
.manage-meta { font-size: 13px; color: #969799; }
.balance-badge { background: #ffebee; color: #ee0a24; padding: 2px 10px; border-radius: 10px; font-size: 12px; font-weight: 500; }

.dialog-form { padding: 12px 0; }
.text-secondary { color: #969799; font-size: 12px; }
