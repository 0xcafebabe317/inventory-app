.contact-page {
  min-height: 100vh;
  display: flex; align-items: center; justify-content: center;
  padding: 32px;
}
.contact-card {
  background: #fff; border-radius: 16px; padding: 32px 24px;
  text-align: center; box-shadow: 0 4px 16px rgba(0,0,0,0.06);
  max-width: 320px; width: 100%;
}
.contact-icon { font-size: 48px; margin-bottom: 16px; }
.contact-title { font-size: 18px; font-weight: 700; color: #323233; margin-bottom: 8px; }
.contact-desc { font-size: 14px; color: #969799; margin-bottom: 24px; line-height: 1.6; }
.qr-wrapper { margin-bottom: 16px; display: flex; justify-content: center; }
.qr-placeholder {
  width: 200px; height: 200px; background: #f5f5f5;
  display: flex; align-items: center; justify-content: center;
  color: #969799; font-size: 14px; border-radius: 8px;
}
.qr-tip { font-size: 13px; color: #969799; }
