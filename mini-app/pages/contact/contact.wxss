.contact-page {
  min-height: 100vh;
  display: flex; align-items: center; justify-content: center;
  padding: 32px;
  background: linear-gradient(180deg, #eff6ff 0%, #f0f4f8 100%);
}
.contact-card {
  background: #fff; border-radius: 16px; padding: 32px 24px;
  text-align: center; box-shadow: 0 4px 16px rgba(0,0,0,0.06);
  max-width: 360px; width: 100%;
}
.contact-icon { font-size: 48px; margin-bottom: 16px; }
.contact-title { font-size: 20px; font-weight: 700; color: #323233; margin-bottom: 12px; }
.contact-desc { font-size: 14px; color: #969799; margin-bottom: 24px; line-height: 1.6; padding: 0 8px; }
.qr-wrapper {
  margin-bottom: 16px;
  display: flex;
  justify-content: center;
}
.qr-image {
  width: 240px;
  border-radius: 8px;
  border: 1px solid #f0f0f0;
}
.qr-placeholder {
  width: 200px; height: 200px; background: #f5f5f5;
  display: flex; align-items: center; justify-content: center;
  color: #969799; font-size: 14px; border-radius: 8px;
}
.qr-tip { font-size: 14px; color: #323233; font-weight: 500; margin-bottom: 4px; }
.qr-tip-sub { font-size: 12px; color: #969799; margin-top: 4px; }
