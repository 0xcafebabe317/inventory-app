<view class="contact-page">
  <view class="contact-card">
    <view class="contact-icon">🔑</view>
    <view class="contact-title">联系管理员</view>
    <view class="contact-desc">
      {{fromForgotPassword ? '如忘记密码，请联系管理员重置密码' : '如需开通权限或咨询问题，请联系管理员'}}
    </view>

    <view class="qr-wrapper" bindtap="previewQrCode">
      <image
        class="qr-image"
        src="/assets/admin-qr.png"
        mode="widthFix"
        show-menu-by-longpress="{{true}}"
      />
    </view>

    <view class="qr-tip">📱 长按图片保存二维码，打开微信扫码添加</view>
    <view class="qr-tip-sub">点击图片可放大查看</view>
  </view>
</view>
