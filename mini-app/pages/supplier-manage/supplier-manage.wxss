.manage-page { background: #f7f8fa; min-height: 100vh; padding-bottom: 40px; }
.toolbar { display: flex; justify-content: space-between; align-items: center; padding: 12px 16px; }

.manage-card {
  background: #fff; border-radius: 12px; padding: 16px;
  margin: 8px 16px; box-shadow: 0 2px 8px rgba(0,0,0,0.04);
}
.card-header { display: flex; align-items: flex-start; gap: 12px; }
.card-avatar {
  width: 42px; height: 42px; min-width: 42px; border-radius: 10px;
  background: linear-gradient(135deg, #e8f0fe, #d2e3fc);
  display: flex; align-items: center; justify-content: center; font-size: 20px;
}
.card-info { flex: 1; min-width: 0; }
.manage-name { font-size: 16px; font-weight: 600; color: #1a1a1a; margin-bottom: 4px; }
.manage-meta { font-size: 13px; color: #646566; display: flex; flex-wrap: wrap; }
.card-actions {
  display: flex; gap: 10px; margin-top: 14px; padding-top: 14px;
  border-top: 1px solid #f0f0f0;
}
.card-actions .van-button { flex: 1; }

/* Popup form */
.popup-title {
  font-size: 18px; font-weight: 700; text-align: center;
  margin-bottom: 20px; color: #1a1a1a;
}
.popup-form {
  margin-bottom: 20px;
}
.popup-actions {
  padding-bottom: env(safe-area-inset-bottom);
}

.text-secondary { color: #969799; font-size: 12px; }
