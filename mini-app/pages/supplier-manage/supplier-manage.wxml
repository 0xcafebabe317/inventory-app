<view class="manage-page">
  <view class="toolbar">
    <text class="text-secondary">共 {{suppliers.length}} 家进货商</text>
    <van-button size="small" type="primary" bindtap="showAdd">新增进货商</van-button>
  </view>

  <view wx:if="{{suppliers.length === 0}}" style="text-align:center;padding:60px 0;color:#969799">
    <van-empty description="暂无进货商">
      <van-button type="primary" size="small" bindtap="showAdd">添加第一个进货商</van-button>
    </van-empty>
  </view>

  <view wx:for="{{suppliers}}" wx:key="id" class="manage-card" data-supplier="{{item}}" bindtap="showEdit">
    <view class="manage-name">{{item.name}}</view>
    <view class="manage-meta">
      <text wx:if="{{item.contact_name}}">{{item.contact_name}}</text>
      <text wx:if="{{item.phone}}" style="margin-left:12px">{{item.phone}}</text>
    </view>
  </view>

  <!-- Add/Edit Dialog -->
  <van-dialog show="{{showDialog}}" title="{{dialogTitle}}" show-cancel-button confirm-loading="{{submitting}}" bind:confirm="handleSubmit" bind:close="closeDialog">
    <view class="dialog-form">
      <van-field value="{{form.name}}" label="名称" required placeholder="进货商名称" data-field="name" bind:change="onInput" />
      <van-field value="{{form.contact_name}}" label="联系人" placeholder="联系人姓名" data-field="contact_name" bind:change="onInput" />
      <van-field value="{{form.phone}}" label="手机" type="number" placeholder="手机号" data-field="phone" bind:change="onInput" />
      <van-field value="{{form.remark}}" label="备注" placeholder="备注" data-field="remark" bind:change="onInput" />
    </view>
  </van-dialog>
</view>
