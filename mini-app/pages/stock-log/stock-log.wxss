.log-page { padding: 12px; }

.log-card {
  background: #fff; border-radius: 10px; padding: 14px 16px; margin-bottom: 8px;
  box-shadow: 0 1px 2px rgba(0,0,0,0.04);
}
.log-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px; }
.log-qty { font-weight: 700; font-size: 15px; margin-left: 8px; }
.log-change { font-size: 13px; color: #646566; font-weight: 500; }
.log-ref { font-size: 12px; color: #969799; margin-bottom: 4px; }

.text-secondary { color: #969799; font-size: 12px; }
