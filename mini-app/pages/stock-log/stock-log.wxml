<view class="log-page">
  <view wx:for="{{logs}}" wx:key="id" class="log-card">
    <view class="log-top">
      <view>
        <van-tag type="{{item.type === 'in' ? 'success' : (item.type === 'out' ? 'danger' : 'primary')}}" size="medium">{{item.type_label}}</van-tag>
        <text class="log-qty">×{{item.qty}}</text>
      </view>
      <text class="log-change">{{item.before_qty}} → {{item.after_qty}}</text>
    </view>
    <view wx:if="{{item.ref_type}}" class="log-ref">来源: {{item.ref_type === 'purchase' ? '进货单' : item.ref_type === 'sale' ? '销售单' : item.ref_type === 'refund' ? '退货单' : '调整'}}</view>
    <text class="text-secondary">{{item.created_at_fmt}}</text>
  </view>
  <van-empty wx:if="{{!loading && logs.length === 0}}" description="暂无流水" />
  <view wx:if="{{loading}}" class="loading-more">加载中...</view>
  <view wx:elif="{{!hasMore && logs.length > 0}}" class="loading-more">— 已加载全部 —</view>
</view>
