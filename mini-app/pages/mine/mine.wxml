<view class="mine-page">
  <!-- Profile -->
  <view class="profile-card">
    <view class="avatar-wrapper" bindtap="chooseAvatar">
      <van-image wx:if="{{userInfo.avatar_url}}" round width="60" height="60" src="{{userInfo.avatar_url}}" use-error-slot>
        <van-icon slot="error" name="user-o" size="32px" color="#c8c9cc" />
      </van-image>
      <view wx:else class="avatar-placeholder">
        <van-icon name="user-o" size="32px" color="#c8c9cc" />
      </view>
      <view class="avatar-overlay" wx:if="{{!uploadingAvatar}}">
        <van-icon name="photograph" size="18px" color="#fff" />
      </view>
      <view class="avatar-overlay uploading" wx:else>
        <van-loading size="18px" color="#fff" />
      </view>
    </view>
    <view class="profile-info">
      <view class="profile-name" bindtap="openNicknameDialog">
        {{userInfo.nickname || '点击设置昵称'}}
        <van-icon name="edit" size="14px" color="#969799" style="margin-left:4px" />
      </view>
      <view class="nickname-row" bindtap="copyNickname">
        <text class="nickname-label">昵称：{{nickname}}</text>
        <van-icon name="records" size="14px" color="#2563eb" style="margin-left:6px" />
      </view>
    </view>
  </view>

  <!-- Expiry Time -->
  <view class="card">
    <view class="expiry-row">
      <text>到期时间</text>
      <text class="expiry-value {{expiryClass}}">{{expiryDisplay}}</text>
    </view>
  </view>

  <!-- Menu -->
  <van-cell-group inset custom-style="margin-top:12px">
    <van-cell title="修改昵称" icon="user-o" is-link bindtap="openNicknameDialog" label="{{canChangeNickname ? '' : '下次可修改：' + nextChangeDate}}" />
    <van-cell title="修改密码" icon="lock" is-link bindtap="openPwdDialog" />
    <van-cell title="进货商管理" icon="shop-o" is-link bindtap="goToSuppliers" />
    <van-cell title="客户管理" icon="friends-o" is-link bindtap="goToCustomers" />
    <van-cell title="联系管理员" icon="service-o" is-link bindtap="goToContact" />
    <van-cell title="关于" icon="info-o" value="v1.0.0" />
  </van-cell-group>

  <view class="logout-area">
    <van-button round block type="danger" bindtap="logout">退出登录</van-button>
  </view>

  <view class="icp-footer">藏ICP备2026000658号</view>

  <!-- Edit Nickname Popup -->
  <van-popup show="{{showNicknameDialog}}" bind:close="closeNicknameDialog" position="bottom" custom-style="padding:20px 16px;border-radius:16px 16px 0 0" round>
    <view class="popup-title">修改昵称</view>
    <view class="popup-rule">昵称每半年只能修改一次，请谨慎设置</view>
    <view class="popup-form">
      <van-field value="{{nicknameForm}}" label="昵称" placeholder="请输入新昵称" bind:change="onNicknameInput" />
    </view>
    <view class="popup-actions">
      <van-button block round type="primary" loading="{{nicknameLoading}}" bindtap="handleUpdateNickname">确认修改</van-button>
      <van-button block round plain type="default" bindtap="closeNicknameDialog" custom-style="margin-top:10px">取消</van-button>
    </view>
  </van-popup>

  <!-- Change Password Popup -->
  <van-popup show="{{showPwdDialog}}" bind:close="closePwdDialog" position="bottom" custom-style="padding:20px 16px;border-radius:16px 16px 0 0" round>
    <view class="popup-title">修改密码</view>
    <view class="popup-form">
      <van-field value="{{pwdForm.oldPassword}}" type="password" label="旧密码" placeholder="请输入旧密码" bind:change="onOldPwdInput" />
      <van-field value="{{pwdForm.newPassword}}" type="password" label="新密码" placeholder="至少8位" bind:change="onNewPwdInput" />
      <van-field value="{{pwdForm.confirmPassword}}" type="password" label="确认密码" placeholder="再次输入新密码" bind:change="onConfirmPwdInput" />
    </view>
    <view class="popup-actions">
      <van-button block round type="primary" loading="{{pwdLoading}}" bindtap="handleChangePwd">确认修改</van-button>
      <van-button block round plain type="default" bindtap="closePwdDialog" custom-style="margin-top:10px">取消</van-button>
    </view>
  </van-popup>
</view>
