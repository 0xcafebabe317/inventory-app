.mine-page { padding: 12px; padding-bottom: 40px; }

.profile-card {
  display: flex; align-items: center; gap: 14px;
  background: #fff; border-radius: 10px; padding: 20px; margin-bottom: 12px;
}
.avatar-wrapper {
  position: relative; width: 60px; height: 60px; border-radius: 50%;
  flex-shrink: 0;
}
.avatar-overlay {
  position: absolute; bottom: 0; right: 0;
  width: 24px; height: 24px; border-radius: 50%;
  background: #2563eb; border: 2px solid #fff;
  display: flex; align-items: center; justify-content: center;
}
.avatar-overlay.uploading { background: #94a3b8; }
.profile-info { flex: 1; }
.profile-name { font-size: 18px; font-weight: 600; margin-bottom: 4px; display: flex; align-items: center; }

.card { background: #fff; border-radius: 10px; padding: 16px; margin-bottom: 12px; }

.expiry-row { display: flex; justify-content: space-between; align-items: center; font-size: 15px; }
.expiry-value {
  font-weight: 600; padding: 4px 12px; border-radius: 20px; font-size: 13px;
}
.expiry-safe { background: #e8f5e9; color: #2e7d32; }
.expiry-danger { background: #ffebee; color: #c62828; }

.dialog-form { padding: 12px 0; }

.logout-area { margin-top: 24px; padding: 0 4px; }

.text-secondary { color: #969799; font-size: 13px; }

.icp-footer {
  text-align: center;
  padding: 24px 0 12px;
  font-size: 22rpx;
  color: #c8c9cc;
}
