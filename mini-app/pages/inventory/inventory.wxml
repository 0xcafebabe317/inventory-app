<view class="container">
  <view class="search-bar">
    <input placeholder="搜索商品名称或条码..." bindinput="onSearch" />
  </view>

  <view class="row space-between mb-12">
    <text class="text-secondary">共 {{total}} 件商品</text>
    <view class="row">
      <text class="tag tag-primary mr-8" bindtap="goToStockCheck">📋 盘点</text>
      <text class="tag tag-primary" bindtap="addProduct">+ 新增商品</text>
    </view>
  </view>

  <view wx:if="{{products.length === 0}}" class="empty-state">
    <text class="text-secondary">暂无商品</text>
    <view class="btn btn-primary mt-16" bindtap="addProduct">添加第一个商品</view>
  </view>

  <view wx:for="{{products}}" wx:key="id" class="product-card card" data-id="{{item.id}}" bindtap="editProduct">
    <view class="row space-between">
      <view class="flex-1">
        <text class="product-name">{{item.name}}</text>
        <text wx:if="{{item.spec}}" class="text-secondary ml-8">{{item.spec}}</text>
      </view>
      <text wx:if="{{item.stock_warn}}" class="tag tag-danger">低库存</text>
    </view>
    <view class="row space-between mt-8">
      <view>
        <text class="text-secondary">库存：</text>
        <text class="{{item.stock_warn ? 'text-danger' : ''}}">{{item.stock_qty}} {{item.unit}}</text>
      </view>
      <view>
        <text class="text-secondary">售价：</text>
        <text>¥{{item.sale_price_fmt}}</text>
      </view>
    </view>
    <view class="row space-between mt-4">
      <text class="text-secondary">条码：{{item.barcode || '-'}}</text>
      <text class="tag tag-primary" data-id="{{item.id}}" catchtap="goToStockLog">流水</text>
    </view>
  </view>

  <view wx:if="{{loading}}" class="loading-more">加载中...</view>
  <view wx:elif="{{!hasMore && products.length > 0}}" class="loading-more">— 已加载全部 —</view>
</view>
