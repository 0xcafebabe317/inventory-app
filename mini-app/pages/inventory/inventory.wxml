<view class="inventory-page">
  <van-search value="{{search}}" placeholder="搜索商品名称" bind:search="onSearch" bind:clear="onClear" />

  <view class="toolbar">
    <text class="text-secondary">共 {{total}} 件</text>
    <van-button size="small" type="primary" bindtap="addProduct">新增商品</van-button>
  </view>

  <view wx:for="{{products}}" wx:key="id" class="product-card" data-id="{{item.id}}" bindtap="editProduct">
    <view class="prod-row">
      <view class="prod-name">
        {{item.name}}
        <van-tag wx:if="{{item.stock_warn}}" type="danger" size="medium">低库存</van-tag>
      </view>
      <text class="prod-price">¥{{item.sale_price_fmt}}</text>
    </view>
    <view class="prod-row">
      <text class="text-secondary">库存: {{item.stock_qty || 0}}{{item.unit || '个'}} · {{item.supplier_name || '未指定供货商'}}</text>
      <van-button size="mini" plain type="primary" data-id="{{item.id}}" catchtap="goToStockLog">流水</van-button>
    </view>
  </view>

  <van-empty wx:if="{{!loading && products.length === 0}}" description="暂无商品">
    <van-button type="primary" size="small" bindtap="addProduct">添加第一个商品</van-button>
  </van-empty>
  <view wx:if="{{loading}}" class="loading-more">加载中...</view>
  <view wx:elif="{{!hasMore && products.length > 0}}" class="loading-more">— 已加载全部 —</view>
</view>
