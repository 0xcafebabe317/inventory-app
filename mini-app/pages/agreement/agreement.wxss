.agreement-page {
  min-height: 100vh;
  background: #f5f5f5;
}
.agreement-content {
  padding: 16px;
}
.title {
  font-size: 20px;
  font-weight: 700;
  text-align: center;
  margin-bottom: 8px;
  color: #1a1a1a;
}
.update-date {
  text-align: center;
  font-size: 12px;
  color: #999;
  margin-bottom: 20px;
}
.section {
  margin-bottom: 16px;
}
.section-title {
  font-size: 15px;
  font-weight: 600;
  color: #333;
  margin-bottom: 8px;
}
.text {
  font-size: 14px;
  color: #555;
  line-height: 1.8;
  margin-bottom: 4px;
}
.text.indent {
  padding-left: 16px;
}
.bold {
  font-weight: 700;
  color: #333;
}
