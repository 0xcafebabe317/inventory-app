.detail-page { background: #f7f8fa; min-height: 100vh; padding: 12px; }

.card { background: #fff; border-radius: 12px; padding: 16px; margin-bottom: 12px; }

.order-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; }
.order-supplier { font-size: 18px; font-weight: 700; }
.order-meta { font-size: 13px; color: #969799; margin-bottom: 4px; }
.order-total { font-size: 28px; font-weight: 700; color: #1a56db; margin-top: 8px; }
.order-remark { font-size: 13px; color: #94a3b8; margin-top: 8px; padding-top: 8px; border-top: 1px solid #f0f0f0; }

.card-title { font-size: 15px; font-weight: 600; margin-bottom: 12px; color: #323233; }

.item-row { display: flex; justify-content: space-between; align-items: center; padding: 12px 0; border-bottom: 1px solid #f5f5f5; }
.item-row:last-child { border-bottom: none; }
.item-left { flex: 1; min-width: 0; }
.item-name { font-size: 15px; font-weight: 500; display: block; margin-bottom: 4px; }
.item-sub { font-weight: 700; font-size: 16px; color: #1a56db; }

.text-secondary { color: #969799; font-size: 12px; }
