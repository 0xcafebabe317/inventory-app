<view class="form-page">
  <view class="card">
    <view class="card-title">{{isEdit ? '编辑商品' : '新增商品'}}</view>

    <van-cell-group inset>
      <van-field label="名称" required value="{{form.name}}" placeholder="商品名称" data-field="name" bind:change="onInput" />
      <van-field label="条码" value="{{form.barcode}}" placeholder="扫码或手动输入" data-field="barcode" bind:change="onInput">
        <van-icon slot="right-icon" name="scan" size="20px" bindtap="onScan" />
      </van-field>
      <van-field label="规格" value="{{form.spec}}" placeholder="型号/规格" data-field="spec" bind:change="onInput" />
      <van-field label="单位" value="{{form.unit}}" placeholder="个/箱/斤..." data-field="unit" bind:change="onInput" />
      <van-field label="售价" type="digit" value="{{form.sale_price}}" placeholder="0.00" data-field="sale_price" bind:change="onInput" />
      <van-field label="批发价" type="digit" value="{{form.wholesale_price}}" placeholder="0.00" data-field="wholesale_price" bind:change="onInput" />
      <van-field label="进价" type="digit" value="{{form.purchase_price}}" placeholder="0.00" data-field="purchase_price" bind:change="onInput" />
      <van-field label="最低库存预警" type="number" value="{{form.min_stock}}" placeholder="低于此数量提醒" data-field="min_stock" bind:change="onInput" />
      <van-field label="进货商" value="{{supplierName}}" placeholder="选择进货商" readonly is-link bind:click-input="openSupplierPicker" />
    </van-cell-group>
  </view>

  <view class="submit-area">
    <van-button type="primary" block round loading="{{submitting}}" bindtap="submit">
      {{isEdit ? '保存修改' : '添加商品'}}
    </van-button>
  </view>

  <!-- Supplier Picker -->
  <van-popup show="{{showSupplierPicker}}" bind:close="closeSupplierPicker" position="bottom" custom-style="height:50%" round>
    <view class="picker-head"><view class="picker-title">选择进货商</view></view>
    <view class="picker-body">
      <view wx:for="{{suppliers}}" wx:key="id" class="picker-item" data-supplier="{{item}}" bindtap="selectSupplier">
        <view class="picker-info">
          <view class="picker-name">{{item.name}}</view>
          <view class="text-secondary">{{item.phone || ''}} · {{item.contact_name || ''}}</view>
        </view>
        <van-icon wx:if="{{form.supplier_id === item.id}}" name="success" color="#1989fa" size="18px" />
      </view>
      <van-empty wx:if="{{suppliers.length === 0}}" description="暂无进货商" />
    </view>
  </van-popup>
</view>
