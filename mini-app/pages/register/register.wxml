<view class="register-page">
  <view class="logo-area">
    <view class="logo-icon">🐰</view>
    <view class="app-title">兔子进销存</view>
    <view class="app-subtitle">注册即享7天免费试用</view>
  </view>

  <view class="form-area">
    <van-cell-group inset>
      <van-field
        value="{{nickname}}"
        placeholder="请输入昵称（唯一标识）"
        left-icon="user-o"
        bind:change="onNicknameInput"
      />
      <van-field
        value="{{password}}"
        placeholder="密码（至少8位）"
        type="{{showPassword ? 'text' : 'password'}}"
        left-icon="lock"
        right-icon="{{showPassword ? 'eye-o' : 'closed-eye'}}"
        bind:change="onPasswordInput"
        bind:click-icon="togglePassword"
      />
      <van-field
        value="{{confirmPassword}}"
        placeholder="确认密码"
        type="{{showConfirmPassword ? 'text' : 'password'}}"
        left-icon="lock"
        right-icon="{{showConfirmPassword ? 'eye-o' : 'closed-eye'}}"
        bind:change="onConfirmInput"
        bind:click-icon="toggleConfirmPassword"
      />
    </van-cell-group>

    <!-- 隐私声明 -->
    <view class="privacy-notice">
      <text class="privacy-icon">🔒</text>
      <text class="privacy-text">您的昵称仅用于注册登录，作为账号唯一标识。昵称每半年可修改一次，不会用于其他任何用途。</text>
    </view>

    <!-- 协议同意 -->
    <view class="agreement-row">
      <van-checkbox value="{{agreed}}" bind:change="onAgreeChange" />
      <text class="agreement-text">我已阅读并同意</text>
      <text class="agreement-link" bindtap="viewAgreement" data-type="service">《用户服务协议》</text>
      <text class="agreement-text">及</text>
      <text class="agreement-link" bindtap="viewAgreement" data-type="privacy">《隐私政策》</text>
    </view>

    <view style="margin: 16px 0">
      <van-button
        type="primary"
        block
        round
        loading="{{submitting}}"
        disabled="{{submitting || !agreed}}"
        bindtap="handleRegister"
        loading-text="注册中..."
      >注册</van-button>
    </view>
  </view>

  <view class="footer-link" bindtap="goLogin">
    已有账号？立即登录
  </view>
</view>
