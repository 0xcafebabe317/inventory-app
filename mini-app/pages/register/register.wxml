<view class="register-page">
  <view class="logo-area">
    <view class="logo-icon">🐰</view>
    <view class="app-title">兔子进销存</view>
    <view class="app-subtitle">注册即享7天免费试用</view>
  </view>

  <view class="form-area">
    <van-cell-group inset>
      <van-field
        value="{{phone}}"
        placeholder="请输入手机号"
        type="number"
        maxlength="11"
        left-icon="phone-o"
        bind:change="onPhoneInput"
      />
      <van-field
        value="{{nickname}}"
        placeholder="昵称（选填）"
        left-icon="user-o"
        bind:change="onNicknameInput"
      />
      <van-field
        value="{{password}}"
        placeholder="密码（至少8位）"
        type="password"
        left-icon="lock"
        bind:change="onPasswordInput"
      />
      <van-field
        value="{{confirmPassword}}"
        placeholder="确认密码"
        type="password"
        left-icon="lock"
        bind:change="onConfirmInput"
      />
    </van-cell-group>

    <view style="margin: 24px 0">
      <van-button
        type="primary"
        block
        round
        loading="{{submitting}}"
        disabled="{{submitting}}"
        bindtap="handleRegister"
        loading-text="注册中..."
      >注册</van-button>
    </view>
  </view>

  <view class="footer-link" bindtap="goLogin">
    已有账号？立即登录
  </view>
</view>
