.register-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #eff6ff 0%, #f0f4f8 100%);
  display: flex;
  flex-direction: column;
  padding-top: 60px;
}
.logo-area {
  text-align: center;
  margin-bottom: 32px;
}
.logo-icon {
  font-size: 60px;
  margin-bottom: 12px;
}
.app-title {
  font-size: 28px;
  font-weight: 700;
  color: #2563eb;
  margin-bottom: 8px;
}
.app-subtitle {
  font-size: 14px;
  color: #94a3b8;
}
.form-area {
  padding: 0 16px;
}
.footer-link {
  text-align: center;
  margin-top: 24px;
  font-size: 14px;
  color: #2563eb;
}
