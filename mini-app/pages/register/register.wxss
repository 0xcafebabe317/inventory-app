.register-page {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  flex-direction: column;
}
.register-bg {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 50px 32px 40px;
}
.logo-area {
  text-align: center;
  margin-bottom: 32px;
}
.logo-icon {
  font-size: 56px;
  margin-bottom: 10px;
}
.app-title {
  font-size: 26px;
  font-weight: 700;
  color: #fff;
  margin-bottom: 6px;
}
.app-subtitle {
  font-size: 14px;
  color: rgba(255,255,255,0.8);
}
.form-card {
  width: 100%;
  background: #fff;
  border-radius: 16px;
  padding: 24px 20px;
  box-shadow: 0 8px 24px rgba(0,0,0,0.12);
}
.footer-link {
  margin-top: 24px;
  font-size: 14px;
  color: rgba(255,255,255,0.85);
}
.link-text {
  color: #ffd54f;
  font-weight: 600;
}
