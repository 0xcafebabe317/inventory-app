# 数据库
MYSQL_ROOT_PASSWORD=change-me-to-a-strong-password

# Redis
REDIS_PASS=change-me-to-a-strong-redis-password

# 运行环境: development | production
ENV=production

# JWT
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars

# 微信小程序
WECHAT_APPID=wx_your_appid
WECHAT_SECRET=your_app_secret

# 管理员账号（仅首次启动无管理员时自动创建）
# 已存在管理员则忽略，不会重置密码
ADMIN_USER=admin
ADMIN_PASS=change-me-to-a-strong-admin-password
